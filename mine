#!/bin/sh
set -eu

if [ "$#" -ne 1 ]; then
    echo 'Usage: readCode "https://video.nice/PayPremium?v=VIDEO_ID"'
    exit 1
fi

need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Error: $1 is not installed."
        exit 1
    }
}

need yt-dlp
need ffmpeg

url=$1

before=$(mktemp)
after=$(mktemp)

trap 'rm -f "$before" "$after"' EXIT HUP INT TERM

find . -maxdepth 1 -type f -name '*.mp4' -print | sort > "$before"

yt-dlp \
    -f 'bv*[ext=mp4]+ba[ext=m4a]/b[ext=mp4]/best' \
    --merge-output-format mp4 \
    -o '%(title).100s.%(ext)s' \
    "$url"

find . -maxdepth 1 -type f -name '*.mp4' -print | sort > "$after"

video=$(comm -13 "$before" "$after" | head -n 1)

if [ -z "$video" ]; then
    video=$(find . -maxdepth 1 -type f -name '*.mp4' -print | sort | tail -n 1)
fi

if [ -z "$video" ]; then
    echo "Error: could not find downloaded mp4."
    exit 1
fi

printf '\nDownloaded: %s\n\n' "$video"

printf 'Trim video? [y/N] '
IFS= read -r ans

case "$ans" in
    y|Y|yes|YES)
        printf 'Start time, example 00:01:10: '
        IFS= read -r start

        printf 'End time, example 00:02:45: '
        IFS= read -r end

        output=${video%.mp4}_trimmed.mp4

        ffmpeg \
            -ss "$start" \
            -to "$end" \
            -i "$video" \
            -c copy \
            "$output"

        printf '\nSaved: %s\n' "$output"
        ;;
    *)
        echo "Done."
        ;;
esac
